# ── Large model weights & checkpoints (regenerated by training, never commit) ──
*.pt
*.pth
*.ckpt
*.bin
*.safetensors
checkpoints/
checkpoints_afrnet/
models/biomedclip/*.bin
models/segmentors/

# ── Datasets & caches (huge, downloaded via save_roco.py / download_roco.py) ──
data/roco/
data/hf_cache/

# ── Experiment tracking & logs ──
wandb/
runs/
logs/
*.log
smoke_log.txt
trace_err.txt

# ── Python virtual env & packaging ──
.venv/
venv/
env/
*.egg-info/
build/
dist/
wheels/

# ── Python bytecode & caches ──
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ipynb_checkpoints/

# ── uv / pip ──
# NOTE: keep pyproject.toml and uv.lock TRACKED — do not ignore them
.uv/

